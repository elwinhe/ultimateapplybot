    {
      "id": "FZy0Jih8SXyUKHnAJRnFK",
      "type": "text",
      "x": 661.2833473291522,
      "y": -1140.3898170068856,
      "width": 1167.885313923442,
      "height": 619.1091194182954,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffffff",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2i",
