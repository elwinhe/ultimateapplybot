      "seed": 1402724062,
      "version": 1658,
      "versionNonce": 1877161310,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1750803953511,
      "link": null,
      "locked": false,
      "text": "Docker stuff\ngitignore\npyproject.toml (uv is faster than pip)\n.env\ntests\n> App\n    |- main.py (starts the app)\n    |- celery_app.py (task queue and job scheduler)\n    |- config.py (settings object for env) \n    > API/V1\n    |    |- email.py (HTTP endpoint router)\n    > Auth\n    |    |- graph_auth.py (gets access token)\n    > Models\n    |    |- email.py (Pydantic model)\n    > Services\n    |    |- graph_client.py (low-level API service layer)\n    |    |- s3.py (s3 upload service)\n    > Tasks\n    |    |- email_tasks.py (bg task that fetches and processes new emails, avoids duplicates w/ redis)\n ",
      "fontSize": 23.58510931117318,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Docker stuff\ngitignore\npyproject.toml (uv is faster than pip)\n.env\ntests\n> App\n    |- main.py (starts the app)\n    |- celery_app.py (task queue and job scheduler)\n    |- config.py (settings object for env) \n    > API/V1\n    |    |- email.py (HTTP endpoint router)\n    > Auth\n    |    |- graph_auth.py (gets access token)\n    > Models\n    |    |- email.py (Pydantic model)\n    > Services\n    |    |- graph_client.py (low-level API service layer)\n    |    |- s3.py (s3 upload service)\n    > Tasks\n    |    |- email_tasks.py (bg task that fetches and processes new emails, avoids duplicates w/ redis)\n ",
      "autoResize": true,
      "lineHeight": 1.25
    },
